---
import type { Locale } from '../i18n/ui';
import { t, otherLocale } from '../i18n/ui';
import { localizePath } from '../i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const other = otherLocale(locale);

// para o toggle de idioma, mantemos o mesmo path no outro idioma
// (o backend pode não ter tradução; nesse caso cai na home do outro idioma)
const togglePath = localizePath(stripLocalePrefix(currentPath), other);

function stripLocalePrefix(path: string): string {
  return path.startsWith('/pt') ? path.slice(3) || '/' : path;
}

const navItems = [
  { key: 'nav.blog' as const,    href: localizePath('/', locale) },
  { key: 'nav.about' as const,   href: localizePath('/about', locale) },
  { key: 'nav.curated' as const, href: localizePath('/curated', locale) },
  { key: 'nav.contact' as const, href: localizePath('/contact', locale) },
];
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={localizePath('/', locale)} aria-label="Iara Santos — home">
      <span class="brand-name">IARA SANTOS</span>
      <span class="brand-tagline">{t(locale, 'home.tagline')}</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href || (item.href === '/' && currentPath === '') }]}
            >
              {t(locale, item.key)}
            </a>
          </li>
        ))}
        <li class="lang-toggle">
          <a href={togglePath} aria-label={t(locale, 'nav.toggleAria')}>
            <span class="lang-current">{locale.toUpperCase()}</span>
            <span class="lang-divider">·</span>
            <span class="lang-other">{t(locale, 'nav.toggle').toLowerCase()}</span>
          </a>
        </li>
      </ul>
    </nav>

    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" id="menu-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--bone);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px);
    background: rgba(245, 242, 237, 0.92);
  }
  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    gap: 2rem;
  }
  .brand {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    line-height: 1;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    letter-spacing: 0.18em;
    color: var(--ink);
  }
  .brand-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.78rem;
    color: var(--ink-muted);
    letter-spacing: 0.01em;
    margin-top: 4px;
    display: none;
  }
  @media (min-width: 720px) {
    .brand-tagline { display: block; }
  }

  .primary-nav { display: none; }
  @media (min-width: 720px) {
    .primary-nav { display: block; }
  }
  .primary-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
    align-items: center;
  }
  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active {
    color: var(--ink);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 1px;
    background: var(--bronze);
  }

  .lang-toggle a {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s var(--ease-editorial);
  }
  .lang-toggle a:hover { color: var(--ink); }
  .lang-current { color: var(--ink); font-weight: 500; }
  .lang-divider { margin: 0 6px; color: var(--sand); }
  .lang-other { color: var(--ink-muted); }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: 0;
    padding: 8px;
  }
  .menu-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--ink);
  }
  @media (min-width: 720px) {
    .menu-toggle { display: none; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.querySelector('.primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
</script>
