---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n/ui';

const locale = 'en' as const;
---

<BaseLayout
  locale={locale}
  title="Contact"
  description="Get in touch with Iara Santos for new opportunities, project conversations, or correspondence."
>
  <section class="contact container">
    <header class="contact-header">
      <p class="eyebrow" data-anim>{t(locale, 'contact.title')}</p>
      <h1 class="display contact-title" data-anim>
        Tell me <em>what you're building.</em>
      </h1>
      <p class="contact-intro">{t(locale, 'contact.intro')}</p>
    </header>

    <div class="contact-grid">
      <!--
        ⚠️ Replace YOUR_FORM_ID with your real Formspree form ID after creating
        a free account at https://formspree.io. Free tier supports 50 submissions/month.
      -->
      <form
        action="https://formspree.io/f/xvzlljye"
        method="POST"
        class="contact-form"
      >
        <label>
          <span>Your name</span>
          <input type="text" name="name" required />
        </label>

        <label>
          <span>Email</span>
          <input type="email" name="email" required />
        </label>

        <label>
          <span>Company / studio (optional)</span>
          <input type="text" name="company" />
        </label>

        <label>
          <span>What's this about?</span>
          <select name="subject" required>
            <option value="">Select…</option>
            <option value="job-opportunity">Job opportunity (full-time / contract)</option>
            <option value="freelance-project">Freelance project</option>
            <option value="lighting-only">Lighting design only</option>
            <option value="issa-project">ISSA Project (PM tool)</option>
            <option value="press-collab">Press / collaboration</option>
            <option value="other">Other</option>
          </select>
        </label>

        <label>
          <span>Tell me more</span>
          <textarea name="message" rows="6" required></textarea>
        </label>

        <button type="submit" class="btn-ghost">Send →</button>
      </form>

      <aside class="contact-aside">
        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.email')}</p>
          <p>
            <a href="mailto:iarasantos.is@icloud.com">
              iarasantos.is@icloud.com
            </a>
          </p>
        </div>

        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.whatsapp')}</p>
          <p>
            <a
              href="https://wa.me/5531983999005"
              target="_blank"
              rel="noopener noreferrer"
            >
              +55 31 98399-9005
            </a>
          </p>
          <p class="aside-fineprint">
            For initial outreach, email or LinkedIn preferred.
          </p>
        </div>

        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.linkedin')}</p>
          <p>
            <a
              href="https://www.linkedin.com/in/arqiarassantos"
              target="_blank"
              rel="noopener noreferrer"
            >
              /in/arqiarassantos
            </a>
          </p>
        </div>

        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.location')}</p>
          <p>Belo Horizonte, Brazil</p>
          <p class="aside-fineprint">
            GMT-3 · Available across US business hours.<br/>
            Open to remote and relocation.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact { padding: 5rem 0 4rem; }
  .contact-header {
    max-width: 50rem;
    margin: 0 auto 4rem;
  }
  .contact-header .eyebrow { margin-bottom: 1.5rem; }
  .contact-title { margin: 0 0 1.5rem; line-height: 1; }
  .contact-intro {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-soft);
    margin: 0;
    max-width: 36rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 800px) {
    .contact-grid {
      grid-template-columns: 1.5fr 1fr;
      gap: 5rem;
    }
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .contact-form span {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    font: inherit;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--rule);
    padding: 0.5rem 0;
    outline: none;
    border-radius: 0;
    transition: border-color 0.2s var(--ease-editorial);
  }
  .contact-form textarea {
    resize: vertical;
    min-height: 8rem;
  }
  .contact-form input:focus,
  .contact-form textarea:focus,
  .contact-form select:focus {
    border-bottom-color: var(--bronze);
  }
  .contact-form button { align-self: flex-start; margin-top: 1rem; }

  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .aside-block { display: flex; flex-direction: column; gap: 0.4rem; }
  .aside-block .eyebrow { margin-bottom: 0.4rem; }
  .aside-block p {
    margin: 0;
    line-height: 1.6;
  }
  .aside-block a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--bronze);
    padding-bottom: 1px;
  }
  .aside-block a:hover { color: var(--bronze); }
  .aside-fineprint {
    font-size: 0.85rem !important;
    color: var(--ink-muted) !important;
    font-style: italic;
    margin-top: 0.25rem !important;
  }
</style>
