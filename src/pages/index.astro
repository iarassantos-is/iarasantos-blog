---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Search from '../components/Search.astro';
import { localizePath } from '../i18n/utils';
import { getPostsByLocale, buildSearchString } from '../utils/posts';

const locale = 'en' as const;
const posts = await getPostsByLocale(locale);
const [hero, ...rest] = posts;
---

<BaseLayout
  locale={locale}
  title="IARA SANTOS"
  description="Interior designer specializing in lighting design and project management. Notes on residential and commercial work, considered."
>
  <section class="masthead container">
    <p class="eyebrow" data-anim>A practice journal</p>
    <h1 class="display masthead-title" data-anim>
      Interiors and light, <em>considered.</em>
    </h1>
    <p class="masthead-lede" data-anim>
      Notes from a practice that treats interior design and lighting as one discipline.
      Project studies, material thinking, and the unglamorous craft of getting things built well.
    </p>
  </section>

  <section class="container posts-section">
    <Search locale={locale} />

    {posts.length === 0 ? (
      <p class="empty">Writing in progress. The first studies arrive shortly.</p>
    ) : (
      <>
        {hero && (
          <div data-searchable data-search-text={buildSearchString(hero)}>
            <PostCard
              locale={locale}
              href={localizePath(`/blog/${hero.slug}`, locale)}
              title={hero.data.title}
              subtitle={hero.data.subtitle}
              category={hero.data.category}
              date={hero.data.publishDate}
              readingTime={hero.data.readingTime}
              cover={hero.data.cover}
              coverAlt={hero.data.coverAlt}
              variant="hero"
            />
          </div>
        )}

        <div class="posts-grid">
          {rest.map((post) => (
            <div data-searchable data-search-text={buildSearchString(post)}>
              <PostCard
                locale={locale}
                href={localizePath(`/blog/${post.slug}`, locale)}
                title={post.data.title}
                subtitle={post.data.subtitle}
                category={post.data.category}
                date={post.data.publishDate}
                readingTime={post.data.readingTime}
                cover={post.data.cover}
                coverAlt={post.data.coverAlt}
              />
            </div>
          ))}
        </div>
      </>
    )}
  </section>
</BaseLayout>

<style>
  .masthead {
    padding: 5rem 0 3.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .masthead .eyebrow { margin-bottom: 1.5rem; }
  .masthead-title {
    max-width: 18ch;
    margin-bottom: 2rem;
    line-height: 1;
  }
  .masthead-lede {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 1.2vw + 0.7rem, 1.4rem);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 38rem;
    margin: 0;
    font-style: italic;
  }

  .posts-section { padding: 4rem 0 2rem; }
  .posts-grid { display: grid; grid-template-columns: 1fr; gap: 0; }
  .empty {
    text-align: center;
    padding: 4rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-muted);
  }
</style>
