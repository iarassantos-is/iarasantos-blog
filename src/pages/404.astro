---
import BaseLayout from '../layouts/BaseLayout.astro';
const locale = 'en' as const;
---

<BaseLayout
  locale={locale}
  title="Not found"
  description="This page does not exist."
>
  <section class="notfound container">
    <p class="eyebrow">404</p>
    <h1 class="display">
      A page that <em>did not become.</em>
    </h1>
    <p class="lede">
      The address you followed leads nowhere — perhaps the writing was unpublished,
      perhaps the link was misspelled. Either way, here are some places to go.
    </p>
    <div class="links">
      <a href="/" class="btn-ghost">Read the latest →</a>
      <a href="/about" class="btn-ghost">About →</a>
      <a href="/contact" class="btn-ghost">Get in touch →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding: 8rem 0;
    text-align: center;
    max-width: 50rem;
  }
  .notfound .eyebrow {
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .notfound .display { margin-bottom: 2rem; }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-soft);
    max-width: 32rem;
    margin: 0 auto 3rem;
  }
  .links { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
</style>
