---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { localizePath } from '../../i18n/utils';
import { getPostsByCategory } from '../../utils/posts';

const locale = 'pt' as const;
const posts = await getPostsByCategory(locale, 'curated');
---

<BaseLayout
  locale={locale}
  title="Curadoria"
  description="Uma lista de leituras com estúdios, projetos e ideias que merecem sua atenção. Curado por Iara Santos."
>
  <section class="curated container">
    <header class="curated-header">
      <p class="eyebrow" data-anim>Curadoria</p>
      <h1 class="display curated-title" data-anim>
        Uma lista de leituras, <em>sempre em movimento.</em>
      </h1>
      <p class="curated-intro">
        Estúdios, projetos e textos aos quais sempre retorno.
        Notas breves sobre por que cada um importa.
      </p>
    </header>

    <div class="curated-list">
      {posts.length === 0 ? (
        <p class="empty">Uma primeira seleção chega em breve.</p>
      ) : (
        posts.map((post) => (
          <PostCard
            locale={locale}
            href={localizePath(`/blog/${post.slug}`, locale)}
            title={post.data.title}
            subtitle={post.data.subtitle}
            category={post.data.category}
            date={post.data.publishDate}
            readingTime={post.data.readingTime}
            cover={post.data.cover}
            coverAlt={post.data.coverAlt}
          />
        ))
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .curated { padding: 5rem 0 4rem; }
  .curated-header {
    max-width: 50rem;
    margin: 0 auto 4rem;
  }
  .curated-header .eyebrow { margin-bottom: 1.5rem; }
  .curated-title { margin: 0 0 1.5rem; line-height: 1; }
  .curated-intro {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink-soft);
    margin: 0;
    max-width: 36rem;
  }
  .empty {
    text-align: center;
    padding: 4rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-muted);
  }
</style>
