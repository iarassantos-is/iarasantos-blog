---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Search from '../../components/Search.astro';
import { localizePath } from '../../i18n/utils';
import { getPostsByLocale, buildSearchString } from '../../utils/posts';

const locale = 'pt' as const;
const posts = await getPostsByLocale(locale);

// ============================================================
// FEATURED TRIO — topo da home
// Para trocar quais 3 posts aparecem em destaque, edite os slugs abaixo.
// Slug = nome do arquivo .md sem extensão (ex: "sobre-a-contencao").
// A ordem desta lista determina a ordem dos cards na página.
// Se um slug não for encontrado na coleção, é ignorado silenciosamente.
// ============================================================
const FEATURED_SLUGS = [
  'como-gerencio-250-projetos',
  'sobre-uma-cozinha-que-respira',
  'luz-que-sabe-o-que-fazer',
] as const;

const featured = FEATURED_SLUGS
  .map((slug) => posts.find((p) => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined);

const rest = posts;
---

<BaseLayout
  locale={locale}
  title="IARA SANTOS"
  description="Designer de interiores especializada em iluminação e gestão de projetos. Apontamentos sobre projetos residenciais e comerciais, com intenção."
>
  <section class="masthead container">
    <p class="eyebrow" data-anim>Caderno de prática</p>
    <h1 class="display masthead-title" data-anim>
      Interiores e luz, <em>com intenção.</em>
    </h1>
    <p class="masthead-lede" data-anim>
      Apontamentos de um ofício que trata interiores e iluminação como uma só disciplina.
      Estudos de projeto, pensamento sobre materiais, texturas e sensações,
      além da parte pouco glamourosa de fazer as coisas de forma bem feita.
    </p>
  </section>

  <section class="container posts-section">
    <Search locale={locale} />

    {posts.length === 0 ? (
      <p class="empty">Os primeiros estudos chegam em breve.</p>
    ) : (
      <>
        {featured.length > 0 && (
          <div class="featured-block">
            <p class="featured-eyebrow">Em destaque</p>
            <div class="featured-grid">
              {featured.map((post) => (
                <div data-searchable data-search-text={buildSearchString(post)}>
                  <PostCard
                    locale={locale}
                    href={localizePath(`/blog/${post.slug}`, locale)}
                    title={post.data.title}
                    subtitle={post.data.subtitle}
                    category={post.data.category}
                    date={post.data.publishDate}
                    readingTime={post.data.readingTime}
                    cover={post.data.cover}
                    coverAlt={post.data.coverAlt}
                    variant="featured"
                  />
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="posts-grid">
          {rest.map((post) => (
            <div data-searchable data-search-text={buildSearchString(post)}>
              <PostCard
                locale={locale}
                href={localizePath(`/blog/${post.slug}`, locale)}
                title={post.data.title}
                subtitle={post.data.subtitle}
                category={post.data.category}
                date={post.data.publishDate}
                readingTime={post.data.readingTime}
                cover={post.data.cover}
                coverAlt={post.data.coverAlt}
              />
            </div>
          ))}
        </div>
      </>
    )}
  </section>
</BaseLayout>

<style>
  .masthead {
    padding: 5rem 0 3.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .masthead .eyebrow { margin-bottom: 1.5rem; }
  .masthead-title {
    max-width: 18ch;
    margin-bottom: 2rem;
    line-height: 1;
  }
  .masthead-lede {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 1.2vw + 0.7rem, 1.4rem);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 38rem;
    margin: 0;
    font-style: italic;
  }

  .posts-section { padding: 4rem 0 2rem; }

  .featured-block {
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--rule);
  }
  .featured-eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bronze);
    margin: 0 0 2rem;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 720px) {
    .featured-grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2.5rem;
    }
  }

  .posts-grid { display: grid; grid-template-columns: 1fr; gap: 0; }
  .empty {
    text-align: center;
    padding: 4rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-muted);
  }
</style>
