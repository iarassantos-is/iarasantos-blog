---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';

const locale = 'pt' as const;
---

<BaseLayout
  locale={locale}
  title="Contato"
  description="Entre em contato com Iara Santos para novas oportunidades, conversas sobre projetos ou correspondência."
>
  <section class="contact container">
    <header class="contact-header">
      <p class="eyebrow" data-anim>{t(locale, 'contact.title')}</p>
      <h1 class="display contact-title" data-anim>
        Me conte <em>o que você está construindo.</em>
      </h1>
      <p class="contact-intro">{t(locale, 'contact.intro')}</p>
    </header>

    <div class="contact-grid">
      <form
        action="https://formspree.io/f/xvzlljye"
        method="POST"
        class="contact-form"
      >
        <label>
          <span>Seu nome</span>
          <input type="text" name="name" required />
        </label>

        <label>
          <span>E-mail</span>
          <input type="email" name="email" required />
        </label>

        <label>
          <span>Empresa / estúdio (opcional)</span>
          <input type="text" name="company" />
        </label>

        <label>
          <span>Sobre o que é?</span>
          <select name="subject" required>
            <option value="">Selecione…</option>
            <option value="job-opportunity">Oportunidade de trabalho (CLT / contrato)</option>
            <option value="freelance-project">Projeto freelance</option>
            <option value="lighting-only">Apenas iluminação</option>
            <option value="issa-project">ISSA Project (ferramenta de gestão)</option>
            <option value="press-collab">Imprensa / colaboração</option>
            <option value="other">Outro</option>
          </select>
        </label>

        <label>
          <span>Me conte mais</span>
          <textarea name="message" rows="6" required></textarea>
        </label>

        <button type="submit" class="btn-ghost">Enviar →</button>
      </form>

      <aside class="contact-aside">
        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.email')}</p>
          <p>
            <a href="mailto:iarasantos.is@icloud.com">
              iarasantos.is@icloud.com
            </a>
          </p>
        </div>

        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.whatsapp')}</p>
          <p>
            <a
              href="https://wa.me/5531983999005"
              target="_blank"
              rel="noopener noreferrer"
            >
              +55 31 98399-9005
            </a>
          </p>
          <p class="aside-fineprint">
            Para primeiro contato, e-mail ou LinkedIn são preferidos.
          </p>
        </div>

        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.linkedin')}</p>
          <p>
            <a
              href="https://www.linkedin.com/in/arqiarassantos"
              target="_blank"
              rel="noopener noreferrer"
            >
              /in/arqiarassantos
            </a>
          </p>
        </div>

        <div class="aside-block">
          <p class="eyebrow">{t(locale, 'contact.location')}</p>
          <p>Belo Horizonte, Brasil</p>
          <p class="aside-fineprint">
            GMT-3 · Disponível em fusos horários dos EUA.<br/>
            Aberta a remoto e relocation.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact { padding: 5rem 0 4rem; }
  .contact-header { max-width: 50rem; margin: 0 auto 4rem; }
  .contact-header .eyebrow { margin-bottom: 1.5rem; }
  .contact-title { margin: 0 0 1.5rem; line-height: 1; }
  .contact-intro {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-soft);
    margin: 0;
    max-width: 36rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 800px) {
    .contact-grid {
      grid-template-columns: 1.5fr 1fr;
      gap: 5rem;
    }
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-form label { display: flex; flex-direction: column; gap: 0.4rem; }
  .contact-form span {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    font: inherit;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--rule);
    padding: 0.5rem 0;
    outline: none;
    border-radius: 0;
    transition: border-color 0.2s var(--ease-editorial);
  }
  .contact-form textarea { resize: vertical; min-height: 8rem; }
  .contact-form input:focus,
  .contact-form textarea:focus,
  .contact-form select:focus {
    border-bottom-color: var(--bronze);
  }
  .contact-form button { align-self: flex-start; margin-top: 1rem; }

  .contact-aside { display: flex; flex-direction: column; gap: 2rem; }
  .aside-block { display: flex; flex-direction: column; gap: 0.4rem; }
  .aside-block .eyebrow { margin-bottom: 0.4rem; }
  .aside-block p { margin: 0; line-height: 1.6; }
  .aside-block a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--bronze);
    padding-bottom: 1px;
  }
  .aside-block a:hover { color: var(--bronze); }
  .aside-fineprint {
    font-size: 0.85rem !important;
    color: var(--ink-muted) !important;
    font-style: italic;
    margin-top: 0.25rem !important;
  }
</style>
